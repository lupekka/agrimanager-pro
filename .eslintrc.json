{
  "parser": "@typescript-eslint/parser",
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react-hooks/recommended"
  ],
  "plugins": [
    "react",
    "@typescript-eslint",
    "react-hooks"
  ],
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    // Regole personalizzate
    "react/react-in-jsx-scope": "off", // Non serve con React 17+
    "react/prop-types": "off", // Usiamo TypeScript
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "@typescript-eslint/no-explicit-any": "warn", // Avviso, non errore
    "no-console": ["warn", { "allow": ["warn", "error"] }] // Permetti console.warn e console.error
  },
  "ignorePatterns": [
    "dist",
    "build",
    "node_modules",
    "*.config.js"
  ]
}
